# ====================================
# 日中汉字对照查询系统 - 环境配置示例
# ====================================
# 复制此文件为 .env 并根据实际情况修改配置值
# 注意：.env 文件不应提交到版本控制系统

# ====================================
# 应用配置
# ====================================

# API 配置
API_V1_STR=/api/v1
PROJECT_NAME=日中汉字互查API
PROJECT_DESCRIPTION=提供日语和中文汉字查询服务的RESTful API
VERSION=1.0.0

# 数据库配置
# 开发环境: ./data/dictionary.db
# Docker 环境: /app/data/dictionary.db
DEFAULT_DB_PATH=./data/dictionary.db

# ====================================
# CORS 配置
# ====================================
# 允许的跨域来源，多个用逗号分隔
# 格式可以是 JSON 数组字符串或逗号分隔的列表
CORS_ORIGINS=["https://jp.jjhh.xyz","http://localhost:3000"]

# ====================================
# JWT 认证配置
# ====================================
# 管理员密码哈希（使用 bcrypt 生成）
# 生成方式: python -c "from passlib.context import CryptContext; import bcrypt; print(bcrypt.hashpw('your_password'.encode(), bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=

# JWT 密钥（请使用强随机字符串）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# JWT 算法
ALGORITHM=HS256

# JWT 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ====================================
# 速率限制配置
# ====================================
# 每分钟请求限制
RATE_LIMIT_PER_MINUTE=60

# ====================================
# 依赖版本说明 (2025-03-18 更新)
# ====================================
# FastAPI: 0.104.1 -> 0.135.1
# Uvicorn: 0.24.0 -> 0.34.0
# SQLAlchemy: 2.0.23 -> 2.0.37
# Pydantic: 2.5.2 -> 2.10.6
# pydantic-settings: 2.1.0 -> 2.7.1
# passlib: 1.7.4 -> 1.8.0
